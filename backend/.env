# ResearchFlow Backend Environment Variables
# Uses the same configuration as research_rag project

# LLM Configuration
LLM_MODE=online
# GEMINI_MODEL="gemini-2.5-flash"
GEMINI_MODEL="glm-4.5"
# GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
GEMINI_BASE_URL="https://open.bigmodel.cn/api/paas/v4/"
GEMINI_API_KEY="your_api_key"
VISION_MODEL="gpt-5-nano"
VISION_BASE_URL="https://api.openai-proxy.org/v1"
VISION_API_KEY="your_api_key"
# Embedding Configuration
EMBEDDING_MODEL="qwen3-embedding:0.6b"
EMBEDDING_MAX_LENGTH=3072
EMBEDDING_BATCH_SIZE=32

# Retrieval Configuration
RETRIEVAL_MODE=balanced

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=researchflow
